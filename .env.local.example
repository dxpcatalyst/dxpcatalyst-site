# Copy to .env.local and fill in. Never commit real values.
# Production values live in Vercel environment variables.

# --- Sanity ---
# The embedded Studio (/studio) runs in the browser, so projectId + dataset
# must be public. Server-only reads use the API token.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: pin the Sanity API version (defaults in sanity/env.ts)
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-side read token for draft/authenticated fetches (never public)
SANITY_API_TOKEN=

# --- HubSpot ---
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_CONTACT_FORM_ID=

# --- ai12z conversational widget ---
NEXT_PUBLIC_AI12Z_API_KEY=

# --- Webhook secret for ai12z content re-sync on Sanity publish ---
SANITY_WEBHOOK_SECRET=
# Optional: ai12z push re-sync endpoint hit by /api/revalidate after a publish
AI12Z_SYNC_WEBHOOK_URL=

# --- Site ---
# Absolute site URL, used for canonical/OG/sitemap
NEXT_PUBLIC_SITE_URL=https://dxpcatalyst.com
